LINE 1: ...ation_to_whitelist_internal('public', 'xxxxxxxx', 'WRONG TYP...
                                                             ^
-- ok
SELECT polar_advisor.add_relation_to_whitelist_internal('pg_catalog', 'pg_class', 'VACUUM');
 add_relation_to_whitelist_internal 
------------------------------------
