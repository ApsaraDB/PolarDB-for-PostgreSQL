/*
 * external/polar_advisor/sql/maintenance_window.sql
 * Test the maintenance window information and functions about it.
 * super_pg client use the window info to do vacuum and reindex.
 */
CREATE EXTENSION IF NOT EXISTS polar_advisor;
NOTICE:  extension "polar_advisor" already exists, skipping
\d+ polar_advisor.advisor_window
                                         Table "polar_advisor.advisor_window"
      Column       |           Type           | Collation | Nullable | Default | Storage  | Stats target | Description 
-------------------+--------------------------+-----------+----------+---------+----------+--------------+-------------
 start_time        | time with time zone      |           | not null |         | plain    |              | 
 end_time          | time with time zone      |           | not null |         | plain    |              | 
 enabled           | boolean                  |           | not null | false   | plain    |              | 
 last_error_time   | timestamp with time zone |           |          |         | plain    |              | 
 last_error_detail | text                     |           |          |         | extended |              | 
 others            | jsonb                    |           |          |         | extended |              | 

SET timezone TO 'PRC';
--
-- Check default window info
--
-- Window has 1 row by default
SELECT * FROM polar_advisor.advisor_window;
 start_time  |  end_time   | enabled | last_error_time | last_error_detail |                             others                             
-------------+-------------+---------+-----------------+-------------------+----------------------------------------------------------------
