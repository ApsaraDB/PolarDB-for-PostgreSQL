/*
 * external/polar_advisor/sql/window_blacklist_vacuum.sql
 * Test the blacklist of vacuum. This case should run before window_vacuum.sql
 * because window_vacuum.sql will do vacuum and update the last_vacuum time,
 * but we need to use the time here.
 */
CREATE EXTENSION IF NOT EXISTS polar_advisor;
NOTICE:  extension "polar_advisor" already exists, skipping
-- ignore the notice printed by polar_advisor.get_relations_to_vacuum_analyze() function
-- which could make the test case unstable
SET client_min_messages TO WARNING;
--
-- show blacklist, empty by default
--
SELECT * FROM polar_advisor.blacklist_relations;
 schema_name | relation_name | action_type 
-------------+---------------+-------------
(0 rows)

SELECT * FROM polar_advisor.get_vacuum_analyze_blacklist();
 schema_name | relation_name | action_type 
-------------+---------------+-------------
(0 rows)

--
-- Get relations to vacuum before setting blacklist, all tables in it
--
SELECT schema_name, rel_name, vacuum_cmd, age >= 0 FROM polar_advisor.get_relations_to_vacuum_analyze (
    result_rows => 1000, sleep_interval => INTERVAL '5 hours',
    table_age_min_limit => -1, table_dead_tup_min_limit => -1
) WHERE schema_name = 'test_polar_advisor' ORDER BY rel_name;
    schema_name     |     rel_name      |                                                                  vacuum_cmd                                                                   | ?column? 
--------------------+-------------------+-----------------------------------------------------------------------------------------------------------------------------------------------+----------
 test_polar_advisor | mv_normal         | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.mv_normal         | t
 test_polar_advisor | normal            | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.normal            | t
 test_polar_advisor | prt_gi            | ANALYZE (VERBOSE, SKIP_LOCKED)  test_polar_advisor.prt_gi                                                                                     | t
 test_polar_advisor | prt_gi_p_0_p_0    | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_gi_p_0_p_0    | t
 test_polar_advisor | prt_gi_p_0_p_1    | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_gi_p_0_p_1    | t
 test_polar_advisor | prt_gi_p_1_p_0    | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_gi_p_1_p_0    | t
 test_polar_advisor | prt_gi_p_1_p_1    | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_gi_p_1_p_1    | t
 test_polar_advisor | prt_gi_p_def      | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_gi_p_def      | t
 test_polar_advisor | prt_no_gi         | ANALYZE (VERBOSE, SKIP_LOCKED)  test_polar_advisor.prt_no_gi                                                                                  | t
 test_polar_advisor | prt_no_gi_p_0_p_0 | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_no_gi_p_0_p_0 | t
 test_polar_advisor | prt_no_gi_p_0_p_1 | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_no_gi_p_0_p_1 | t
 test_polar_advisor | prt_no_gi_p_1_p_0 | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_no_gi_p_1_p_0 | t
 test_polar_advisor | prt_no_gi_p_1_p_1 | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_no_gi_p_1_p_1 | t
 test_polar_advisor | prt_no_gi_p_def   | VACUUM (VERBOSE, FREEZE, ANALYZE, SKIP_LOCKED, TRUNCATE, PARALLEL 2, PROCESS_TOAST, INDEX_CLEANUP AUTO)  test_polar_advisor.prt_no_gi_p_def   | t
