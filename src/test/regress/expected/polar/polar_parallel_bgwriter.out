-- alter parallel bgwriter workers to a big value.
alter system set polar_parallel_flush_workers = 25;
ERROR:  25 is outside the valid range for parameter "polar_parallel_flush_workers" (0 .. 24)
alter system set polar_parallel_flush_workers = 8;
select pg_reload_conf();
