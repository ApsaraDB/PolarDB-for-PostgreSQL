 b      | character varying(10) |           |          |         | extended |              | 
 c      | character(10)         |           |          |         | extended |              | 
Partition key: RANGE (a)
Indexes:
    "t_a_idx" btree (a)
Partitions: t_p1 FOR VALUES FROM (0) TO (100)

\d+ t_p1
                          Table "test_attach_partition_nocheck_constraint.t_p1"
 Column |         Type          | Collation | Nullable | Default | Storage  | Stats target | Description 
--------+-----------------------+-----------+----------+---------+----------+--------------+-------------
 a      | integer               |           |          |         | plain    |              | 
 b      | character varying(10) |           |          |         | extended |              | 
 c      | character(10)         |           |          |         | extended |              | 
Partition of: t FOR VALUES FROM (0) TO (100)
Partition constraint: ((a IS NOT NULL) AND (a >= 0) AND (a < 100))
Indexes:
    "t_p1_a_idx" btree (a)

SELECT * FROM t WHERE a = 1;
 a | b |     c      
---+---+------------
 1 | 1 | 1         
(1 row)

CREATE TABLE t_p2(a int, b varchar(10), c char(10));
ALTER TABLE t_p2 REPLICA IDENTITY DEFAULT;
INSERT INTO t_p2 VALUES(101, '101', '101');
-- disable check constraint, error should be raised
SET polar_enable_skip_partition_constraint_check TO off;
ALTER TABLE t ATTACH PARTITION t_p2 FOR VALUES FROM (100) TO (200) NOCHECK_CONSTRAINT;
ERROR:  ATTACH PARTITION with NOCHECK_CONSTRAINT option is not supported.
HINT:  Please enable the "polar_enable_skip_partition_constraint_check" GUC.
