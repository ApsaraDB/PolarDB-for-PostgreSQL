-------------------------------------------------
-- init
-------------------------------------------------
CREATE SCHEMA test_attach_partition_nocheck_constraint;
SET search_path TO test_attach_partition_nocheck_constraint;
-- range partition
CREATE TABLE t(a int, b varchar(10), c char(10)) PARTITION BY RANGE (a);
CREATE INDEX on t(a);
\d+ t
                     Partitioned table "test_attach_partition_nocheck_constraint.t"
 Column |         Type          | Collation | Nullable | Default | Storage  | Stats target | Description 
--------+-----------------------+-----------+----------+---------+----------+--------------+-------------
 a      | integer               |           |          |         | plain    |              | 
 b      | character varying(10) |           |          |         | extended |              | 
 c      | character(10)         |           |          |         | extended |              | 
Partition key: RANGE (a)
Indexes:
    "t_a_idx" btree (a)
Number of partitions: 0

